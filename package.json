{
  "name": "@arnoldgraf/cross-tab-worker",
  "version": "0.1.5",
  "description": "Drop-in coordination wrapper that keeps exactly one Worker alive across all same-origin tabs.",
  "repository": {
    "type": "git",
    "url": "https://github.com/arnold-graf/cross-tab-worker"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run tests",
    "test:watch": "vitest tests",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npm run build && playwright test --project=chromium",
    "test:e2e:webkit": "npm run build && playwright test --project=webkit",
    "test:e2e:webkit:headed": "npm run build && playwright test --project=webkit --ui"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
